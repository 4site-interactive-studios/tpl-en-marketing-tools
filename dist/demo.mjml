<mjml lang="en">
  <mj-head>
    <mj-breakpoint width="600px" />
    <mj-title>TPL Email Template — Demo Catalog</mj-title>
    <mj-preview>Preview text placeholder — update per send.</mj-preview>

    <!-- Baseline everything inherits -->
    <mj-attributes>
      <mj-text
        color="#000000"
        font-size="18px"
        font-weight="400"
        font-family="Tahoma, sans-serif"
        line-height="24px"
        css-class="wysiwyg"
      />
      <mj-button width="auto"
        css-class="button"
        font-size="18px"
        font-weight="700"
        font-family="Tahoma, sans-serif"
        line-height="25px"
        border-radius="100px"
        inner-padding="12px 16px"
        letter-spacing="2px"
        color="#ffffff"
        background-color="#006837"
      />
      <mj-image
        padding="0" />

      <!-- Reusable variants — apply with mj-class="*" -->
      <mj-class
        name="caption"
        font-size="10px"
        line-height="16px"
        padding="8px 0 0 0"
      />
    </mj-attributes>

    <mj-style>
      @media (max-width: 599px) {
        /* Indents the caption */
        .caption {
          padding-left: 16px !important;
          padding-right: 16px !important;
        }

        /* Side by Side CTA Buttons */
        .cta-item { display: block !important; margin: 0 0 16px 0 !important; }
        .cta-item:last-child { margin-bottom: 0 !important; }
      }
    </mj-style>

    <mj-raw>
      <meta name="color-scheme" content="light dark" />
      <meta name="supported-color-schemes" content="light dark" />
      <meta name="format-detection" content="telephone=no" />
    </mj-raw>
    <mj-include path="./styles.css" type="css" />
  </mj-head>
  <mj-body css-class="email-body" background-color="#ffffff">

    <mj-include path="./partials/debug-toolbar.mjml" />

    <!-- START: Main Content -->

    <!-- START: Category — Logo Headers -->
    <mj-raw><div data-import-exclude="true"></mj-raw>
    <mj-section css-class="text-block block" background-color="#111111" padding="10px 32px" data-style-padding-top data-style-padding-right data-style-padding-bottom data-style-padding-left data-style-background-color data-style-border data-style-direction>
      <mj-column data-style-background-color data-style-border data-style-padding-top data-style-padding-right data-style-padding-bottom data-style-padding-left data-style-vertical-align>
        <mj-text padding="0" align="center" data-style-alignment data-style-padding-top data-style-padding-right data-style-padding-bottom data-style-padding-left data-style-color>
          <p style="font-size:14px;font-weight:700;letter-spacing:3px;color:#8DC63F;font-family:Menlo,Consolas,monospace;">LOGO HEADERS</p>
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-raw></div></mj-raw>
    <!-- END: Category — Logo Headers -->

    <!-- START: Logo Header (light green, left) -->
    <mj-section css-class="image-block block" background-color="#CEE4C5" padding="16px 32px" data-style-padding-top data-style-padding-right data-style-padding-bottom data-style-padding-left data-style-background-color data-style-border data-style-direction>
      <mj-column vertical-align="middle" data-style-background-color data-style-border data-style-padding-top data-style-padding-right data-style-padding-bottom data-style-padding-left data-style-vertical-align>
        <mj-image css-class="light-only" src="assets/logo-tpl_color-black-text.png" alt="Trust for Public Land" href="https://www.example.com" width="150px" align="left" data-style-src data-style-href data-style-alt data-style-width data-style-align />
        <mj-raw><!--[if !mso]><!--></mj-raw>
        <mj-image css-class="dark-only" src="assets/logo-tpl_color-black-text.png" alt="Trust for Public Land" href="https://www.example.com" width="150px" align="left" data-style-src data-style-href data-style-alt data-style-width data-style-dark-mode data-style-align />
        <mj-raw><!--<![endif]--></mj-raw>
      </mj-column>
    </mj-section>
