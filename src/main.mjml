              src="assets/staff-carrie-besnette-hauser.png"
              alt="Custom alt text"
              padding="0"
          />
        </mj-column>
        <mj-column
          vertical-align="middle"
          width="365px"
          css-class="signature-text"
          padding-left="10px"
        >
          <mj-image
              src="assets/staff-carrie-besnette-hauser-signature_black.png"
              alt="Signature Image"
              width="228px"
              padding="0 0 10px"
              align="left"
              css-class="light-only"
          />
