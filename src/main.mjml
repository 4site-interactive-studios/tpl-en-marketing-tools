      <mj-column vertical-align="middle">
        <mj-text color="#ffffff" align="center">Hello World</mj-text>
      </mj-column>
      </mj-group>
    </mj-section>
    <!-- END: Text w/ Background Image -->

    <!-- START: Image x CTA Split Block w/ Fixed Height Background Image (w/ dark-mode swap) -->
    <mj-section
      css-class="image-block block"
      background-color="#362229"
      padding="264px 32px 16px 32px"
      background-url="assets/photo-trail.jpg"
      background-size="cover"
      background-repeat="no-repeat"
      background-position="center center"
    >
      <mj-group>
      <mj-column vertical-align="bottom" width="50%">
        <mj-image
          src="assets/logo-tpl_color-light-green-text.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          padding="0 16px 0 0"
          css-class="light-only"
          align="left"
        />
        <mj-raw><!--[if !mso]><!--></mj-raw>
        <mj-image
          src="assets/logo-tpl_color-light-green-text.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          padding="0 16px 0 0"
          css-class="dark-only"
          align="left"
        />
        <mj-raw><!--<![endif]--></mj-raw>
      </mj-column>
      <mj-column vertical-align="bottom" width="50%">
          <mj-button
            href="https://www.example.com"
            align="right" padding="0"
          >
            Read more
          </mj-button>
      </mj-column>
      </mj-group>
    </mj-section>
    <!-- END: Image x CTA Split Block w/ Fixed Height Background Image (w/ dark-mode swap) -->    

    <!-- START: Image with overlay -->
    <!--
      Inside a section using a background all elements must have 0 left
      and right padding or they will be misaligned on outlook.
      This is why we use spacer columns with a fixed width on the sides
      of the overlay image column to create the necessary padding while
      maintaining alignment across email clients.
     -->
    <mj-section
        css-class="overlay-image-block block"
        background-url="assets/photo-person_overlay.png"
        background-size="cover"
        background-repeat="no-repeat"
        background-position="center bottom"
        padding="350px 16px 48px 16px"
    >
      <mj-group>
        <!-- Spacer column - required to be done this way for Outlook -->
        <mj-column width="25px">&nbsp;</mj-column>

        <mj-column width="550px">
          <mj-text css-class="overlay">
            <h1 style="text-align: center">Placeholder message for special occasion </h1>
          </mj-text>
          <mj-button
            href="https://www.example.com"
          >
            Button
          </mj-button>
        </mj-column>

        <!-- Spacer column - required to be done this way for Outlook -->
        <mj-column width="25px">&nbsp;</mj-column>
      </mj-group>
    </mj-section>
    <!-- END: Image with overlay -->

    <!-- START: Image -->
    <mj-section
      css-class="image-block block"
      background-color="#ffffff"
      padding="0"
    >
      <mj-column vertical-align="middle">
        <mj-image
          src="assets/photo-family.png"
          alt="Image Alt Text"
          href="https://www.example.com"
          width="600px"
          padding="0"
        />
      </mj-column>
    </mj-section>
    <!-- END: Image -->

    <!-- START: Caption -->
    <mj-section
      css-class="block caption"
      background-color="#ffffff"
      padding="0"
    >
      <mj-column vertical-align="middle">
        <mj-text align="right" mj-class="caption">
          <span>Photography by Photographers Name, Agency</span>
        </mj-text>
      </mj-column>
    </mj-section>
    <!-- END: Caption -->

    <!-- START: Two Images -->
    <mj-section
      css-class="two-col-images-block block"
      background-color="#ffffff"
      padding="0"
    >
      <mj-column css-class="two-col-column first-column" width="300px" padding="0 8px 0 0" vertical-align="middle">
        <mj-image
          src="assets/photo-family.png"
          alt="Custom alt text"
          href="https://www.example.com"
          padding="0"
          align="center"
          fluid-on-mobile="true"
        />
      </mj-column>
      <mj-column css-class="two-col-column" width="300px" padding="0 0 0 8px" vertical-align="middle">
        <mj-image
          src="assets/photo-family.png"
          alt="Custom alt text"
          href="https://www.example.com"
          padding="0"
          align="center"
          fluid-on-mobile="true"
        />
      </mj-column>
    </mj-section>
    <!-- END: Two Images -->

    <!-- START: WYSIWYG Text (full width) -->
    <mj-section
      css-class="text-block block"
      background-color="#ffffff"
      padding="0"
    >
      <mj-column>
        <mj-text padding="0">
          <h1>
            Lorem ipsum quis malesuada sed quam faucibus.
