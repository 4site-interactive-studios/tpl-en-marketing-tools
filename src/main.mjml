<mjml lang="en">
  <mj-head>
    <mj-breakpoint width="600px" />
    <mj-title>TPL Email Template — Block Catalog</mj-title>
    <mj-preview>Preview text placeholder — update per send.</mj-preview>

    <!-- Baseline everything inherits -->
    <mj-attributes>
      <mj-text
        color="#000000"
        font-size="18px"
        font-weight="400"
        font-family="Tahoma, sans-serif"
        line-height="24px"
        css-class="wysiwyg"
      />
      <mj-button
        css-class="button"
        font-size="21px"
        font-weight="700"
        font-family="Tahoma, sans-serif"
        line-height="25px"
        border-radius="100px"
        inner-padding="12px 16px"
        letter-spacing="2px"
        color="#ffffff"
        background-color="#006837"
      />
      <mj-image
        padding="0"
      />

      <!-- Reusable variants — apply with mj-class="*" -->
      <mj-class
        name="caption"
        font-size="10px"
        line-height="16px"
        padding="8px 0 0 0"
      />
    </mj-attributes>

    <mj-style>
      @media (max-width: 599px) {
        /* Indents the caption (!important beats the inline td padding) */
        .caption {
          padding-left: 16px !important;
          padding-right: 16px !important;
        }

        /* Side by Side CTA Buttons */
        .cta-item { display: block !important; margin: 0 0 16px 0 !important; }
        .cta-item:last-child { margin-bottom: 0 !important; }
      }
    </mj-style>

    <mj-raw>
      <meta name="color-scheme" content="light dark" />
      <meta name="supported-color-schemes" content="light dark" />
      <meta name="format-detection" content="telephone=no" />
    </mj-raw>
    <mj-include path="./styles.css" type="css" />
  </mj-head>
  <mj-body css-class="email-body" background-color="#ffffff">

    <mj-include path="./partials/debug-toolbar.mjml" />

    <!-- START: Main Content -->

    <!-- START: Logo Header (white, w/ dark-mode swap) -->
    <mj-section
      css-class="image-block block"
      background-color="#ffffff"
      padding="16px 32px"
    >
      <mj-column vertical-align="middle">
        <mj-image
          src="assets/logo-tpl_color-black-text.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          css-class="light-only"
        />
        <mj-raw><!--[if !mso]><!--></mj-raw>
        <mj-image
          src="assets/logo-tpl_all-light-green.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          css-class="dark-only"
        />
        <mj-raw><!--<![endif]--></mj-raw>
      </mj-column>
    </mj-section>
    <!-- END: Logo Header (white, w/ dark-mode swap) -->

    <!-- START: Logo Header (light green, w/ dark-mode swap) -->
    <mj-section
      css-class="image-block block"
      background-color="#F5FAF1"
      padding="16px 32px"
    >
      <mj-column vertical-align="middle">
        <mj-image
          src="assets/logo-tpl_color-black-text.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          css-class="light-only"
        />
        <mj-raw><!--[if !mso]><!--></mj-raw>
        <mj-image
          src="assets/logo-tpl_all-light-green.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          css-class="dark-only"
        />
        <mj-raw><!--<![endif]--></mj-raw>
      </mj-column>
    </mj-section>
    <!-- END: Logo Header (light green, w/ dark-mode swap) -->

    <!-- START: Image x Image Centered Block (w/ dark-mode swap) -->
    <mj-section
      css-class="image-block block"
      background-color="#700310"
      padding="16px 32px"
    >
      <mj-group>
      <mj-column vertical-align="middle" width="50%">
        <mj-image
          src="assets/logo-tpl_all-light-green.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          padding="0 16px 0 0"
          css-class="light-only"
          align="right"
        />
        <mj-raw><!--[if !mso]><!--></mj-raw>
        <mj-image
          src="assets/logo-tpl_all-light-green.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          padding="0 16px 0 0"
          css-class="dark-only"
          align="right"
        />
        <mj-raw><!--<![endif]--></mj-raw>
      </mj-column>
      <mj-column vertical-align="middle" width="50%">
        <mj-image
          src="assets/state-north-carolina.png"
          alt="Logo"
          href="https://www.example.com"
          width="100px"
          padding="0 0 0 16px"
