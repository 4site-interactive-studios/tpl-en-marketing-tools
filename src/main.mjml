    <!-- START: Triple CTA Buttons (centered, fixed width) -->
    <!--
      SHARED BUTTON WIDTH FORMULA (round DOWN so they never wrap):
        width = ( sectionWidth - leftPadding - rightPadding - (buttonCount - 1) * gap ) / buttonCount

        sectionWidth : 600   (= email width here; use the section's own width if narrower)
        padding      : 32 + 32
        gap          : 32     (between buttons)
        buttonCount  : 3
        => (600 - 32 - 32 - (3 - 1) * 32) / 3 = 472 / 3 = 157.3 -> 157px

      If any value changes, update width:157px on every <a> AND width="157"/width:157px on every MSO <td>.
    -->
