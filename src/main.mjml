        <mj-column css-class="question-response-text" width="562px" vertical-align="top" padding="8px 16px 8px 0">
          <mj-text padding="0">
            <p><a href="https://www.example.com">Each list item will functions as a link in the email directing users to a dedicated page on your site.</a></p>
          </mj-text>
        </mj-column>
      </mj-group>
    </mj-section> -->
