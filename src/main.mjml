    >
      <mj-column css-class="two-col-column first-column" width="240px" padding="0 16px 0 0" vertical-align="top">
        <mj-image
          src="assets/image-ranking.png"
          alt="2026 ParkScore ranking: number 8"
          href="https://www.example.com"
          padding="0"
          align="center"
          width="224px"
        />
      </mj-column>
      <mj-column css-class="two-col-column" width="296px" padding="0" vertical-align="top">
        <mj-text padding="0">
          <p>
            We released our 15th annual ParkScore index yesterday, and Seattle
            ranks #8 nationwide based on strong measurements for acreage,
            access, investment, amenities, and equity. Although the Emerald
            City fell out of the top 10 in 2020, it came back to the top 10
            list in 2021 and has stayed there ever since.
          </p>
        </mj-text>
      </mj-column>
    </mj-section>
    <!-- END: Side by side image and text (image left) -->

