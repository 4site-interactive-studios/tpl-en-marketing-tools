<mjml>
  <mj-head>
    <mj-breakpoint width="600px" />

    <!-- Baseline everything inherits -->
    <mj-attributes>
      <mj-text
        color="#000000"
        font-size="18px"
        font-weight="400"
        font-family="Tahoma, san-serif"
        line-height="24px"
        css-class="wysiwyg"
      />
      <mj-button
        css-class="button"
        font-size="21px"
        font-weight="700"
        font-family="Tahoma, san-serif"
        line-height="25px"
        border-radius="100px"
        inner-padding="12px 16px"
        letter-spacing="2px"
        color="#ffffff"
        background-color="#006837"
      />
      <mj-image
        padding="0"
      />

      <!-- Reusable variants — apply with mj-class="*" -->
      <mj-class
        name="caption"
        font-size="10px"
        line-height="16px"
        padding="8px 0 0 0"
      />
    </mj-attributes>

    <mj-style>
      /* Indents the caption */
      @media (max-width: 619px) {
        .caption {
          padding-left: 16px !important; /* must be !important — beats the inline td padding */
          padding-right: 16px !important; /* must be !important — beats the inline td padding */
        }
      }

      /* Side by Side CTA Buttons */
      @media (max-width: 619px) {
        .cta-item { display: block !important; margin: 0 0 16px 0 !important; }
        .cta-item:last-child { margin-bottom: 0 !important; }
      }
    </mj-style>

    <mj-raw>
      <meta name="color-scheme" content="light dark" />
      <meta name="supported-color-schemes" content="light dark" />
      <meta name="format-detection" content="telephone=no" />
    </mj-raw>
    <!-- <mj-preview>Hello MJML</mj-preview> -->
    <mj-include path="./styles.css" type="css" />
  </mj-head>
  <mj-body css-class="email-body" background-color="#ffffff">
    <!-- START: Main Content -->

    <!-- START: Image Block (with Dark Mode) -->
    <mj-section
      css-class="image-block block"
      background-color="#ffffff"
      padding="16px 32px"
    >
      <mj-column vertical-align="middle">
        <mj-image
          src="assets/logo-tpl_color-black-text.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          css-class="light-only"
        />
        <mj-raw><!--[if !mso]><!--></mj-raw>
        <mj-image
          src="assets/logo-tpl_all-light-green.png"
          alt="Logo"
          href="https://www.example.com"
          width="150px"
          css-class="dark-only"
        />
        <mj-raw><!--<![endif]--></mj-raw>
      </mj-column>
    </mj-section>
    <!-- END: Image Block -->

    <!-- START: Image Block (with Dark Mode) -->
    <mj-section
      css-class="image-block block"
      background-color="#F5FAF1"
      padding="16px 32px"
