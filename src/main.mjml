    <mj-section css-class="text-block block" background-color="#362229" padding="16px 32px 0">
      <mj-column>
        <mj-text padding="0" color="#ffffff">
          <p style="font-size:16px;font-weight:700;letter-spacing:2px;">IN THE SPOTLIGHT</p>
          <h3 style="color:#ffffff;">Guess Who's Finding Their Happiness Outside More than Ever? (It Might Surprise You!) 🤔</h3>
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-section css-class="image-block block" background-color="#362229" padding="8px 32px 0">
      <mj-column width="50%" padding="0 10px 0 0" vertical-align="top">
        <mj-image src="assets/photo-people-on-fence.png" alt="Teens sitting together on a fence" href="https://www.example.com" width="248px" align="center" padding="0 0 12px" border="3px solid #F7941D" border-radius="18px" />
        <mj-text padding="0 0 16px" align="center">
          <a href="https://www.example.com" style="display:inline-block;background-color:#ffffff;color:#006837;border-radius:100px;width:200px;padding:10px 0;text-align:center;font-family:Tahoma,sans-serif;font-size:18px;font-weight:700;letter-spacing:2px;line-height:24px;text-decoration:none;mso-padding-alt:0;white-space:nowrap;">AGES 13-17</a>
        </mj-text>
      </mj-column>
      <mj-column width="50%" padding="0 0 0 10px" vertical-align="top">
        <mj-image src="assets/photo-couple-hiking.png" alt="Couple hiking in the mountains" href="https://www.example.com" width="248px" align="center" padding="0 0 12px" border="3px solid #8DC63F" border-radius="18px" />
        <mj-text padding="0 0 16px" align="center">
          <a href="https://www.example.com" style="display:inline-block;background-color:#ffffff;color:#006837;border-radius:100px;width:200px;padding:10px 0;text-align:center;font-family:Tahoma,sans-serif;font-size:18px;font-weight:700;letter-spacing:2px;line-height:24px;text-decoration:none;mso-padding-alt:0;white-space:nowrap;">AGES 25-34</a>
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-section css-class="image-block block" background-color="#362229" padding="0 32px 0">
      <mj-column width="50%" padding="0 10px 0 0" vertical-align="top">
        <mj-image src="assets/photo-couple-fishing.png" alt="Couple fishing beside a forest creek" href="https://www.example.com" width="248px" align="center" padding="0 0 12px" border="3px solid #5FC9C5" border-radius="18px" />
        <mj-text padding="0 0 16px" align="center">
          <a href="https://www.example.com" style="display:inline-block;background-color:#ffffff;color:#006837;border-radius:100px;width:200px;padding:10px 0;text-align:center;font-family:Tahoma,sans-serif;font-size:18px;font-weight:700;letter-spacing:2px;line-height:24px;text-decoration:none;mso-padding-alt:0;white-space:nowrap;">AGES 45-54</a>
        </mj-text>
      </mj-column>
      <mj-column width="50%" padding="0 0 0 10px" vertical-align="top">
        <mj-image src="assets/photo-couple-on-water.png" alt="Older couple relaxing in chairs by the water" href="https://www.example.com" width="248px" align="center" padding="0 0 12px" border="3px solid #39B54A" border-radius="18px" />
        <mj-text padding="0 0 16px" align="center">
          <a href="https://www.example.com" style="display:inline-block;background-color:#ffffff;color:#006837;border-radius:100px;width:200px;padding:10px 0;text-align:center;font-family:Tahoma,sans-serif;font-size:18px;font-weight:700;letter-spacing:2px;line-height:24px;text-decoration:none;mso-padding-alt:0;white-space:nowrap;">AGES 65+</a>
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-section css-class="text-block block" background-color="#362229" padding="0 32px 16px">
      <mj-column>
        <mj-text padding="0" color="#ffffff">
          <p style="font-size:16px;">Not in a guessing mood? <a href="https://www.example.com" style="color:#ffffff;font-weight:bold;">Skip to the answer.</a></p>
        </mj-text>
        <mj-text mj-class="caption" color="#ffffff">
          <span>Photos: Bergreen Photography, Chris Bennett, Caroline Martin, Sara Rubinstein</span>
        </mj-text>
      </mj-column>
    </mj-section>
    <!-- END: In the Spotlight Block (2x2 photo quiz, dark background) -->

    <!-- START: Feedback Poll Block (framed by tri-color dividers) -->
    <mj-include path="./partials/tri-color-divider.mjml" />
    <mj-section css-class="text-block block" background-color="#ffffff" padding="16px 32px">
      <mj-column>
        <mj-text padding="0">
          <p style="font-size:17px;font-weight:700;">Were the topics in this newsletter important?</p>
          <p style="font-size:16px;"><img src="assets/icon-heart_green.png" alt="" width="22" height="22" style="vertical-align:middle;border:0;" />&nbsp;&nbsp;<a href="https://www.example.com" style="color:#006837;font-weight:bold;">Very important</a></p>
          <p style="font-size:16px;"><img src="assets/icon-thumbs-up.png" alt="" width="22" height="22" style="vertical-align:middle;border:0;" />&nbsp;&nbsp;<a href="https://www.example.com" style="color:#006837;font-weight:bold;">Somewhat important</a></p>
          <p style="font-size:16px;"><img src="assets/icon-prohibited.png" alt="" width="22" height="22" style="vertical-align:middle;border:0;" />&nbsp;&nbsp;<a href="https://www.example.com" style="color:#006837;font-weight:bold;">Not important</a></p>
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-include path="./partials/tri-color-divider.mjml" />
    <!-- END: Feedback Poll Block (framed by tri-color dividers) -->

    <!-- START: Signature Card (original) -->
    <mj-section css-class="signature-block block" background-color="#ffffff" padding="20px 20px 0">
      <mj-column width="480px">
        <mj-text padding="0">
          <p style="font-style: italic;">
            With deep appreciation,
          </p>
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-section css-class="signature-block block" background-color="#ffffff" padding="16px 16px">
      <mj-group width="480px">
        <mj-column
          vertical-align="top"
          width="110px"
          css-class="signature-img"
          padding-right="10px"
        >
