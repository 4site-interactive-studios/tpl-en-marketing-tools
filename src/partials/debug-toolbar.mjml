<!-- START: Debug Toolbar (dev only — remove for production) -->
<mj-raw>
  <div id="tpl-debug-btn" title="Toggle debug mode"
       onclick="if(window.__tplDebug){window.__tplDebug.toggle();}else{var s=document.createElement('script');s.src='assets/debug.js';s.onload=function(){window.__tplDebug.enable();};document.body.appendChild(s);}"
       style="position:fixed;bottom:16px;right:16px;width:44px;height:44px;border-radius:50%;background:#111111;font-size:20px;line-height:44px;text-align:center;cursor:pointer;z-index:2147483646;box-shadow:0 2px 10px rgba(0,0,0,.35);user-select:none;">🐞</div>
</mj-raw>
<!-- END: Debug Toolbar (dev only — remove for production) -->
