      </mj-column>
    </mj-section>
    <mj-section css-class="image-block block" background-color="#F5FAF1" border="1px solid #D9E3D9" padding="16px 32px">
      <mj-column vertical-align="middle">
        <mj-image src="assets/logo-tpl_all-black.png" alt="Trust for Public Land" href="https://www.example.com" width="150px" align="left" />
      </mj-column>
    </mj-section>
    <mj-section css-class="image-block block" background-color="#F5FAF1" border="1px solid #D9E3D9" padding="16px 32px">
