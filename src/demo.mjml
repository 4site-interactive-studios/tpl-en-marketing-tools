<mjml>
  <mj-head>
    <mj-breakpoint width="600px" />

    <!-- Baseline everything inherits -->
    <mj-attributes>
      <mj-text
        color="#000000"
        font-size="18px"
        font-weight="400"
        font-family="Tahoma, sans-serif"
        line-height="24px"
        css-class="wysiwyg"
      />
      <mj-button
        css-class="button"
        font-size="21px"
        font-weight="700"
        font-family="Tahoma, sans-serif"
        line-height="25px"
        border-radius="100px"
        inner-padding="12px 16px"
        letter-spacing="2px"
        color="#ffffff"
        background-color="#006837"
      />
      <mj-image
        padding="0"
      />

      <!-- Reusable variants — apply with mj-class="*" -->
      <mj-class
        name="caption"
        font-size="10px"
        line-height="16px"
        padding="8px 0 0 0"
      />
    </mj-attributes>

    <mj-style>
      /* Indents the caption */
      @media (max-width: 619px) {
        .caption {
          padding-left: 16px !important;
          padding-right: 16px !important;
        }
      }

      /* Side by Side CTA Buttons */
      @media (max-width: 619px) {
        .cta-item { display: block !important; margin: 0 0 16px 0 !important; }
        .cta-item:last-child { margin-bottom: 0 !important; }
      }
    </mj-style>

    <mj-raw>
      <meta name="color-scheme" content="light dark" />
      <meta name="supported-color-schemes" content="light dark" />
      <meta name="format-detection" content="telephone=no" />
    </mj-raw>
    <mj-include path="./styles.css" type="css" />
  </mj-head>
  <mj-body css-class="email-body" background-color="#ffffff">
    <!-- START: Main Content -->

    <!-- START: Image (full-bleed) w/ Caption -->
    <mj-section css-class="image-block block" background-color="#ffffff" padding="0">
      <mj-column vertical-align="middle">
        <mj-image src="assets/photo-family.png" alt="Family celebrating on a mountain overlook" href="https://www.example.com" width="600px" padding="0" />
      </mj-column>
    </mj-section>
    <mj-section css-class="block caption" background-color="#ffffff" padding="0">
      <mj-column vertical-align="middle">
        <mj-text align="right" mj-class="caption">
          <span>Photograph by Photographer&rsquo;s Name, AGENCY</span>
        </mj-text>
      </mj-column>
    </mj-section>
    <!-- END: Image (full-bleed) w/ Caption -->

    <!-- START: Image (inset) w/ Caption -->
    <mj-section css-class="image-block block" background-color="#ffffff" padding="16px 48px">
      <mj-column vertical-align="middle">
        <mj-image src="assets/photo-family.png" alt="Family celebrating on a mountain overlook" href="https://www.example.com" padding="0" />
        <mj-text align="right" mj-class="caption">
          <span>Photograph by Photographer&rsquo;s Name, AGENCY</span>
        </mj-text>
      </mj-column>
    </mj-section>
    <!-- END: Image (inset) w/ Caption -->

    <!-- START: Text Block (mixed-weight heading) -->
    <mj-section css-class="text-block block" background-color="#ffffff" padding="16px 0">
      <mj-column width="480px">
        <mj-text padding="0">
          <h1 style="font-weight:400;color:#362229;">Lorem Ipsum <b>Dolor Sit Amet Consectetur. Pulvinar Feugi</b></h1>
          <p style="font-size:16px;">
            Lorem ipsum dolor sit amet consectetur. Morbi adipiscing convallis
            vitae quisque commodo volutpat ut. Cursus sed quam ornare augue
            quis metus. Fermentum sit id pharetra tortor. In viverra semper et
            lorem consequat pellentesque. Proin urna urna massa ut quis augue
            pulvinar senectus aenean.
          </p>
        </mj-text>
      </mj-column>
    </mj-section>
    <!-- END: Text Block (mixed-weight heading) -->

    <!-- START: Logo Header Permutations -->
    <mj-section css-class="image-block block" background-color="#CEE4C5" padding="16px 32px">
      <mj-column vertical-align="middle">
        <mj-image src="assets/logo-tpl_color-black-text.png" alt="Trust for Public Land" href="https://www.example.com" width="150px" align="left" />
      </mj-column>
    </mj-section>
    <mj-section css-class="image-block block" background-color="#CEE4C5" padding="16px 32px">
      <mj-column vertical-align="middle">
        <mj-image src="assets/logo-tpl_color-black-text.png" alt="Trust for Public Land" href="https://www.example.com" width="150px" align="center" />
      </mj-column>
    </mj-section>
    <mj-section css-class="image-block block" background-color="#362229" padding="16px 32px">
      <mj-column vertical-align="middle">
        <mj-image src="assets/logo-tpl_all-light-green.png" alt="Trust for Public Land" href="https://www.example.com" width="150px" align="left" />
      </mj-column>
    </mj-section>
    <mj-section css-class="image-block block" background-color="#362229" padding="16px 32px">
