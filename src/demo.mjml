    <!-- START: Photo CTA Banner (centered headline + gift button) -->
    <mj-section css-class="image-block block" background-color="#006837" padding="48px 32px" background-url="assets/photo-forest.jpg" background-size="cover" background-repeat="no-repeat" background-position="center center">
      <mj-column>
        <mj-text align="center" padding="0 0 16px" color="#ffffff">
