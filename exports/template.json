,\n    h6 {\n      color: {replacement~headings_color};\n      font-family: {replacement~headings_font};\n    }\n\n\th1 {\n\t  font-size: 32px;\n\t  line-height: 42px; /* 32 * 1.3 */\n\t  mso-line-height-rule: exactly;\n\t}\n\t  \n\th2 {\n\t  font-size: 28px;\n\t  line-height: 36px; /* 28 * 1.3 */\n\t\tmso-line-height-rule: exactly;\n\t}\n\t  \n\th3 {\n\t  font-size: 22px;\n\t  line-height: 29px; /* 22 * 1.3 */\n\t\tmso-line-height-rule: exactly;\n\t}\n\t  \n\th4,\n\th5,\n\th6 {\n\t  font-size: 18px;\n\t  line-height: 29px; /* 18 * 1.6 */\n\t\tmso-line-height-rule: exactly;\n\t}\n\t  \n\tp {\n\t  font-size: 16px;\n\t  line-height: 27px; /* 16 * 1.7 */\n\t\tmso-line-height-rule: exactly;\n\t}\n\t  \n    .wysiwyg>div>*:first-child {\n      margin-top: 0;\n    }\n\n    .wysiwyg>div>*:last-child {\n      margin-bottom: 0;\n    }\n\n    .mobile-only {\n      display: none !important;\n    }\n\n    .two-col-column h3 {\n      margin-bottom: 0;\n    }\n\n    .footer-text p,\n    .footer-text span,\n    .footer-text a,\n    .footer-text li {\n      font-size: 12px;\n\t  line-height: 20px;\n      font-family: Arial, sans-serif;\n\t  mso-line-height-rule: exactly;\n    }\n\t  \n    .overlay h1,\n    .overlay h2,\n    .overlay h3,\n    .overlay h4,\n    .overlay h5,\n    .overlay h6,\n    .overlay span,\n    .overlay p,\n    .overlay a {\n      color: #ffffff;\n    }\n\n    @media (max-width: 599px) {\n      .desktop-only {\n        display: none !important;\n      }\n\n      .signature-img {\n        width: 110px !important;\n      }\n\n      .signature-text {\n        width: calc(100% - 110px) !important;\n      }\n\n      .two-col-column>table>tbody>tr>td {\n        padding: 0 !important;\n      }\n\n      /* Add space below image on mobile when it is collapsed to single column */\n      .two-col-image>table {\n        margin-bottom: 15px !important;\n      }\n\n      /* Add space below first column on mobile when it is collapsed to single column */\n      .first-two-col-column,\n      .first-column,\n      .second-column {\n        margin-bottom: 20px;\n      }\n\n      .caption {\n        padding-left: 20px !important;\n        padding-right: 20px !important;\n      }\n\n\t  .question-response-symbol {\n\t    width: 40px !important;\n\t  }\n\t\n\t  .question-response-text {\n\t    width: calc(100% - 40px) !important;\n\t  }\n    }\n\n    /* dark mode styles */\n    :root {\n      color-scheme: light dark;\n      supported-color-schemes: light dark;\n    }\n\n    .dark-only {\n      display: none;\n    }\n\n    [data-ogsc] .dark-only {\n      display: block !important;\n    }\n\n    [data-ogsc] .light-only {\n      display: none !important;\n    }\n\n    @media (prefers-color-scheme: dark) {\n      .light-only {\n        display: none !important;\n      }\n\n      .dark-only {\n        display: block !important;\n      }\n\n      body,\n      .email-body {\n        color: #eeeeee !important;\n        background-color: #171819 !important;\n      }\n\n      a {\n        color: #9ca4a5 !important;\n      }\n\n      .wysiwyg h1,\n      .wysiwyg h2,\n      .wysiwyg h3,\n      .wysiwyg h4,\n      .wysiwyg h5,\n      .wysiwyg h6,\n      .pre-footer-text span {\n        color: #b0b4b5 !important;\n      }\n\n\t\t.quote-block p,\n      .footer-block p {\n        color: #eeeeee !important;\n      }\n\n      .block,\n      .block>table,\n      .spacer-block td {\n        background-color: #1f2021 !important;\n      }\n\n      .quote-block,\n      .quote-block>table,\n      .cta-button-block,\n      .cta-button-block>table,\n      .highlighted-text-column>table>tbody>tr>td {\n        background-color: #2b2a2a !important;\n      }\n\n      .button td,\n      .button a {\n        background-color: #eaebec !important;\n        border-color: #eaebec !important;\n        color: #121314 !important;\n      }\n\n      .social-link table {\n        background-color: #0e0f0f !important;\n      }\n\n      .divider>p {\n        border-color: #eeeeee !important;\n      }\n\n  .question-response {\n    background-color: #2b2a2a !important;\n    border-color: #eee !important;;\n    color: #eeeeee !important;\n  }\n\n  .question-response p a {\n    color: #eeeeee !important;\n  }\n\n      .question-response:hover {\n        background-color: #1f2021 !important;\n        cursor: pointer;\n      }\n    }\n\n    /* sizing classes for adjustable column widths 50-550px */\n    @media only screen and (min-width:600px) {\n\n      .mj-column-px-50,\n      .moz-text-html .mj-column-px-50 {\n        width: 50px !important;\n        max-width: 50px;\n      }\n\n      .mj-column-px-100,\n      .moz-text-html .mj-column-px-100 {\n        width: 100px !important;\n        max-width: 100px;\n      }\n\n      .mj-column-px-150,\n      .moz-text-html .mj-column-px-150 {\n        width: 150px !important;\n        max-width: 150px;\n      }\n\n      .mj-column-px-200,\n      .moz-text-html .mj-column-px-200 {\n        width: 200px !important;\n        max-width: 200px;\n      }\n\n      .mj-column-px-250,\n      .moz-text-html .mj-column-px-250 {\n        width: 250px !important;\n        max-width: 250px;\n      }\n\n      .mj-column-px-300,\n      .moz-text-html .mj-column-px-300 {\n        width: 300px !important;\n        max-width: 300px;\n      }\n\n      .mj-column-px-350,\n      .moz-text-html .mj-column-px-350 {\n        width: 350px !important;\n        max-width: 350px;\n      }\n\n      .mj-column-px-400,\n      .moz-text-html .mj-column-px-400 {\n        width: 400px !important;\n        max-width: 400px;\n      }\n\n      .mj-column-px-450,\n      .moz-text-html .mj-column-px-450 {\n        width: 450px !important;\n        max-width: 450px;\n      }\n\n      .mj-column-px-500,\n      .moz-text-html .mj-column-px-500 {\n        width: 500px !important;\n        max-width: 500px;\n      }\n\n      .mj-column-px-550,\n      .moz-text-html .mj-column-px-550 {\n        width: 550px !important;\n        max-width: 550px;\n      }\n